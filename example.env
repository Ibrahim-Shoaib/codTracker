# ============================================================
# SHOPIFY APP
# ============================================================
# From Shopify Partner Dashboard > Apps > Your App > API credentials
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
# Optional. When unset, the app uses CANONICAL_SCOPES from app/shopify.server.ts
# (the full list required for ad tracking). Only set this if you intentionally
# want a smaller scope set in dev — otherwise leave it empty and let the
# canonical list flow through, so production never falls behind shopify.app.toml.
# SHOPIFY_SCOPES=
# The public URL of your app (Railway URL in production, ngrok URL in dev)
SHOPIFY_APP_URL=https://your-app.railway.app

# ============================================================
# SUPABASE
# ============================================================
# From Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key — only used server-side, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================
# META (FACEBOOK) ADS
# ============================================================
# From Meta Developer Console > Your App > Settings > Basic
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# OAuth redirect URI — must match exactly what is registered in Meta app settings
META_REDIRECT_URI=https://your-app.railway.app/auth/meta/callback

# ─── Ad Tracking (Pixel Tracking flow, separate from ads_read above) ──────────
# Configuration ID from Meta App Dashboard → Facebook Login for Business →
# Configurations → "Pixel Tracking" (created from the Conversions API template).
META_PIXEL_CONFIG_ID=your_pixel_tracking_config_id
# Must match one of the redirect URIs configured on the Pixel Tracking config.
META_PIXEL_REDIRECT_URI=https://your-app.railway.app/auth/meta-pixel/callback
# Optional: set to a Test Event Code from Events Manager to route the
# "Send test event" page button to the dev test stream instead of production.
META_TEST_EVENT_CODE=

# ============================================================
# POSTEX API
# ============================================================
# NOTE: PostEx tokens are per-merchant and stored in the Supabase
# `stores` table, NOT here. This is only used for local dev/testing.
POSTEX_API_TOKEN=your_postex_api_token_for_local_testing

# ============================================================
# RAILWAY CRON SECRET
# ============================================================
# A random secret to authenticate Railway cron job HTTP calls
# to your app's internal cron endpoints. Generate with: openssl rand -hex 32
CRON_SECRET=your_random_cron_secret_here

# ============================================================
# SESSION / ENCRYPTION
# ============================================================
# Used by Remix + Shopify App Template for session storage encryption
# Generate with: openssl rand -hex 32
SESSION_SECRET=your_random_session_secret_here

# Encrypts BISU tokens at rest in meta_pixel_connections.bisu_token (AES-256-GCM).
# Must be a separate value from SESSION_SECRET — leaking one shouldn't compromise the other.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_random_encryption_key_here

# ============================================================
# APP ENVIRONMENT
# ============================================================
NODE_ENV=development
# Set to 'production' on Railway
